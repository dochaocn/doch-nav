{
  "manifest_version": 3,
  "name": "个人导航站",
  "version": "1.0.0",
  "description": "新标签页个人导航：常用链接、网页暂存、高频站点；数据随 Chrome 同步到 Google 账号。",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "topSites", "activeTab"],
  "optional_permissions": ["history"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "一键暂存当前页到「暂存」"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
